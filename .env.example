# ── Database ────────────────────────────────────────────────────────────────
# Transaction-mode pooler URL (used by the app at runtime via pgbouncer)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Session-mode pooler URL (used by prisma migrate / prisma studio)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://trysarion.com"   # no trailing slash
NODE_ENV="production"

# ── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=""          # openssl rand -base64 32
BETTER_AUTH_URL="https://trysarion.com"

# ── Stripe (Sarion subscription billing only) ────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Create recurring prices in Stripe (monthly + yearly per tier) and paste IDs.
# Standard prices:
STRIPE_PRICE_STARTER_MONTHLY="price_..."  # $19/mo
STRIPE_PRICE_STARTER_YEARLY="price_..."   # $190/yr
STRIPE_PRICE_GROWTH_MONTHLY="price_..."   # $49/mo
STRIPE_PRICE_GROWTH_YEARLY="price_..."    # $490/yr
STRIPE_PRICE_AGENCY_MONTHLY="price_..."   # $99/mo
STRIPE_PRICE_AGENCY_YEARLY="price_..."    # $990/yr
# Founding (locked-forever) prices — optional; fall back to standard if unset.
STRIPE_PRICE_STARTER_MONTHLY_FOUNDING="price_..."
STRIPE_PRICE_STARTER_YEARLY_FOUNDING="price_..."
STRIPE_PRICE_GROWTH_MONTHLY_FOUNDING="price_..."
STRIPE_PRICE_GROWTH_YEARLY_FOUNDING="price_..."
STRIPE_PRICE_AGENCY_MONTHLY_FOUNDING="price_..."
STRIPE_PRICE_AGENCY_YEARLY_FOUNDING="price_..."
# Founding offer toggle — set to "false" at launch-end to close it to new signups.
NEXT_PUBLIC_FOUNDING_OFFER_OPEN="true"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Transactional email for invites, auth flows, and contact-form delivery.
# Create a key at https://resend.com/api-keys. REQUIRED in production —
# without it the app falls back to logging emails to the console.
RESEND_API_KEY=""
# Verified sender in Resend, e.g. "Sarion <hello@trysarion.com>"
EMAIL_FROM="hello@trysarion.com"

# ── Contact ───────────────────────────────────────────────────────────────────
# Inbox that contact-form submissions are delivered to (server-side).
CONTACT_EMAIL="hello@trysarion.com"
# Public address shown in the UI / mailto fallbacks.
NEXT_PUBLIC_CONTACT_EMAIL="hello@trysarion.com"

# ── Plausible Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="trysarion.com"   # omit to disable analytics

# ── Google Analytics (gtag.js) ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-0WFPXKHKVM"               # omit to disable

# ── Sentry Error Monitoring ────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""   # https://...@o0.ingest.sentry.io/...
SENTRY_ORG=""               # your Sentry org slug
SENTRY_PROJECT=""           # your Sentry project slug
SENTRY_AUTH_TOKEN=""        # for source map uploads at build time
