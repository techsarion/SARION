# ── Database ────────────────────────────────────────────────────────────────
# Transaction-mode pooler URL (used by the app at runtime via pgbouncer)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Session-mode pooler URL (used by prisma migrate / prisma studio)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://trysarion.com"   # no trailing slash
NODE_ENV="production"

# ── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=""          # openssl rand -base64 32
BETTER_AUTH_URL="https://trysarion.com"

# ── Lemon Squeezy (Sarion subscription billing only) ─────────────────────────
# Create an API key at https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=""
# Numeric store ID (Settings → Stores, or the number in the store URL).
LEMONSQUEEZY_STORE_ID=""
# Webhook signing secret (Settings → Webhooks → your endpoint).
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Create a subscription product per tier with a monthly + yearly variant, then
# paste each variant's numeric ID. All optional — the billing UI shows a "not
# configured" banner until they're set.
LEMON_STARTER_MONTHLY_VARIANT_ID=""   # $19/mo
LEMON_STARTER_YEARLY_VARIANT_ID=""    # $190/yr
LEMON_GROWTH_MONTHLY_VARIANT_ID=""    # $49/mo
LEMON_GROWTH_YEARLY_VARIANT_ID=""     # $490/yr
# Optional — only needed if the Agency tier is sold self-serve.
LEMON_AGENCY_MONTHLY_VARIANT_ID=""    # $99/mo
LEMON_AGENCY_YEARLY_VARIANT_ID=""     # $990/yr
# Founding offer toggle — set to "false" at launch-end to close it to new signups.
NEXT_PUBLIC_FOUNDING_OFFER_OPEN="true"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Transactional email for invites, auth flows, and contact-form delivery.
# Create a key at https://resend.com/api-keys. REQUIRED in production —
# without it the app falls back to logging emails to the console.
RESEND_API_KEY=""
# Verified sender in Resend, e.g. "Sarion <hello@trysarion.com>"
EMAIL_FROM="hello@trysarion.com"

# ── Contact ───────────────────────────────────────────────────────────────────
# Inbox that contact-form submissions are delivered to (server-side).
CONTACT_EMAIL="hello@trysarion.com"
# Public address shown in the UI / mailto fallbacks.
NEXT_PUBLIC_CONTACT_EMAIL="hello@trysarion.com"

# ── PostHog Product Analytics ──────────────────────────────────────────────────
# Project API key (Project Settings → API Keys). Public — safe in the browser.
# Omit to disable analytics entirely (all tracking calls become no-ops).
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# Ingestion host: https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU).
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Optional separate server-side key; falls back to NEXT_PUBLIC_POSTHOG_KEY.
POSTHOG_KEY=""

# ── Plausible Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="trysarion.com"   # omit to disable analytics

# ── Google Analytics (gtag.js) ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-0WFPXKHKVM"               # omit to disable

# ── Ahrefs Web Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_AHREFS_KEY="IhWr28QdB+uyLM7zL3CrXw"  # data-key from Ahrefs; omit to disable

# ── Sentry Error Monitoring ────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""   # https://...@o0.ingest.sentry.io/...
SENTRY_ORG=""               # your Sentry org slug
SENTRY_PROJECT=""           # your Sentry project slug
SENTRY_AUTH_TOKEN=""        # for source map uploads at build time
