{
  "name": "sarion",
  "version": "0.1.0",
  "private": true,
  "description": "Agency CRM + Client Portal for small agencies.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
