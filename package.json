    "@sentry/nextjs": "^10.57.0",
    "better-auth": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^17.0.0",
    "tailwind-merge": "^3.6.0",
