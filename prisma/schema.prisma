// Sarion — Agency CRM + Client Portal
// 8 MVP entities per docs/MVP-PRD.md §7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // transaction pooler (pgbouncer) — app runtime
  directUrl = env("DIRECT_URL")   // session pooler — migrations & introspection
}

enum Role {
  owner
  member
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum InvoiceStatus {
  paid
  unpaid
  overdue
}

enum PlanTier {
  free
  starter
  growth
  agency
}

enum BillingInterval {
  monthly
  yearly
}

enum FeedbackType {
  feature_request
  bug_report
  general
}

enum FeedbackStatus {
  open
  in_review
  planned
  completed
  declined
}

// Idempotency ledger for Lemon Squeezy webhooks. Each event is processed at
// most once; a duplicate delivery is short-circuited on the unique eventId.
model LemonWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  createdAt DateTime @default(now())
}

model Agency {
  id                 String   @id @default(cuid())
  name               String
  logoUrl            String?
  // --- Billing / plan (see src/config/plans.ts for the source of truth) ---
  planTier             PlanTier        @default(free)
  billingInterval      BillingInterval @default(monthly)
  // Launch-cohort flag. Retained for lifetime perks / badge; Lemon Squeezy has
  // no per-customer locked price so it no longer affects which variant is sold.
  foundingMember       Boolean         @default(false)
  // 14-day no-card trial. Null once the agency has converted to a paid plan.
  trialEndsAt          DateTime?
  // --- Lemon Squeezy billing identifiers ---
  lemonCustomerId      String?
  lemonOrderId         String?
  lemonSubscriptionId  String?
  // Subscription lifecycle (normalized): trialing | active | past_due | canceled | unpaid | incomplete
  subscriptionStatus   String          @default("trialing")
  // Next invoice sequence number to assign (per-agency). Atomically incremented
  // during invoice creation — see src/server/services/invoice-number.ts.
  invoiceSequence    Int      @default(1)
  // Whether the starter sample workspace has been seeded (F8 onboarding).
  seeded             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt @default(now())

  users          User[]
  clients        Client[]
  projects       Project[]
  invoices       Invoice[]
  tasks          Task[]
  invoiceItems   InvoiceItem[]
  comments       Comment[]
  activities     Activity[]
  teamInvites    TeamInvite[]
  portalComments PortalComment[]
  feedback       Feedback[]
}

// In-app feedback from authenticated users — feature requests, bug reports, and
// general feedback. Reviewed by agency owners at /settings/feedback.
model Feedback {
  id          String         @id @default(cuid())
  agencyId    String
  userId      String
  type        FeedbackType   @default(general)
  title       String
  description String
  status      FeedbackStatus @default(open)
  createdAt   DateTime       @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
  @@index([status])
}

model User {
  id            String   @id @default(cuid())
  agencyId      String
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(owner)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agency   Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  sessions Session[]
  accounts Account[]
  feedback Feedback[]

  @@index([agencyId])
}

// --- Better Auth tables (email/password) ---

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Client {
  id          String   @id @default(cuid())
  agencyId    String
  name        String
  company     String?
  email       String?
  phone       String?
  notes       String?
  portalToken String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  deletedAt   DateTime?

  agency     Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  projects   Project[]
  invoices   Invoice[]
  comments   Comment[]
  activities Activity[]

  @@index([agencyId])
}

// Append-only audit trail. Most events are client-scoped, but agency-level
// events (e.g. team member invited) have a null clientId.
model Activity {
  id          String   @id @default(cuid())
  agencyId    String
  clientId    String?
  projectId   String?
  type        String
  description String
  createdAt   DateTime @default(now())

  agency  Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
}

model Project {
  id          String        @id @default(cuid())
  agencyId    String
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(PLANNED)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt @default(now())
  deletedAt   DateTime?

  agency         Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks          Task[]
  comments       Comment[]
  activities     Activity[]
  portalComments PortalComment[]

  @@index([agencyId])
  @@index([clientId])
  @@index([agencyId, status])
}

model Task {
  id        String  @id @default(cuid())
  agencyId  String
  projectId String
  title     String
  isDone    Boolean @default(false)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  agency  Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([agencyId])
}

model Invoice {
  id        String        @id @default(cuid())
  agencyId  String
  clientId  String
  number    String
  status    InvoiceStatus @default(unpaid)
  issueDate DateTime      @default(now())
  dueDate   DateTime?
  total     Decimal       @default(0) @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt @default(now())
  deletedAt DateTime?

  agency Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  items  InvoiceItem[]

  @@unique([agencyId, number])
  @@index([agencyId])
  @@index([clientId])
  @@index([agencyId, status, dueDate])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  agencyId    String
  invoiceId   String
  description String
  qty         Int     @default(1)
  unitPrice   Decimal @default(0) @db.Decimal(10, 2)
  lineTotal   Decimal @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  agency  Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([agencyId])
}

model Comment {
  id         String   @id @default(cuid())
  agencyId   String
  clientId   String
  projectId  String?
  authorName String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  agency  Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectId])
  @@index([agencyId])
}

// F2 — pending team member invitations. Members always join with role=member;
// acceptance is wired through the Better Auth signup hook (matched by email).
model TeamInvite {
  id         String    @id @default(cuid())
  agencyId   String
  name       String
  email      String
  token      String    @unique @default(cuid())
  role       Role      @default(member)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([email])
}

// F5 — client-portal discussion threads, scoped to a project. Authored by the
// client (unauthenticated, identified by the portal token), so no user link.
model PortalComment {
  id        String   @id @default(cuid())
  agencyId  String
  projectId String
  author    String
  message   String
  createdAt DateTime @default(now())

  agency  Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([agencyId])
}
